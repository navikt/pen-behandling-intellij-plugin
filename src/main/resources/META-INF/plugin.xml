<idea-plugin>
    <id>no.nav.pensjon.pen.behandling-plugin</id>
    <name>PEN Behandling Generator</name>
    <vendor>NAV Pensjon</vendor>
    <description><![CDATA[
        Genererer kode for nye behandlinger og aktiviteter i PEN's behandlingsløsning.
        <ul>
            <li>New → PEN Behandling: Oppretter en behandlingsklasse med første aktivitet</li>
            <li>Alt+Enter i en behandlings- eller aktivitetfil → "Legg til ny aktivitet i denne behandlingen"</li>
            <li>Inspeksjoner for navnekonvensjoner og manglende annotasjoner</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <localInspection
                groupName="PEN Behandling"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="no.nav.pensjon.pen.plugin.inspection.BehandlingInspection"
                displayName="Behandling conventions (@Entity, @DiscriminatorValue, @ForvalgtAnsvarligTeam)"/>
        <localInspection
                groupName="PEN Behandling"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="no.nav.pensjon.pen.plugin.inspection.AktivitetInspection"
                displayName="Aktivitet conventions (@Entity, @DiscriminatorValue, naming, Processor)"/>
        <localInspection
                groupName="PEN Behandling"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="no.nav.pensjon.pen.plugin.inspection.ProcessorInspection"
                displayName="AktivitetProcessor conventions (@Component, type consistency)"/>
        <intentionAction>
            <className>no.nav.pensjon.pen.plugin.intention.AddAktivitetIntentionAction</className>
            <category>PEN Behandling</category>
        </intentionAction>
        <intentionAction>
            <className>no.nav.pensjon.pen.plugin.intention.RenameAktivitetIntentionAction</className>
            <category>PEN Behandling</category>
        </intentionAction>
    </extensions>

    <actions>
        <action id="PenBehandling.NewBehandling"
                class="no.nav.pensjon.pen.plugin.action.NewBehandlingAction"
                text="PEN Behandling"
                description="Opprett en ny behandling med første aktivitet"
                icon="AllIcons.Nodes.Class">
            <add-to-group group-id="NewGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
