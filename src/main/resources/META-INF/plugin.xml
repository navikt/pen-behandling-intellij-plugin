<idea-plugin>
    <id>no.nav.pensjon.pen.behandling-plugin</id>
    <name>PEN Behandling Generator</name>
    <vendor>NAV Pensjon</vendor>
    <description><![CDATA[
        Generates boilerplate code for new Behandlinger and Aktiviteter in PEN's behandlingsløsning.
        <ul>
            <li>New → PEN Behandling → Behandling: Creates a Behandling class with initial Aktivitet</li>
            <li>Alt+Enter in a Behandling or Aktivitet file → "Add new Aktivitet to this Behandling"</li>
            <li>Inspections for naming conventions and missing annotations</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <localInspection
                groupName="PEN Behandling"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="no.nav.pensjon.pen.plugin.inspection.DiscriminatorValueInspection"
                displayName="@DiscriminatorValue should not end with 'Behandling'"/>
        <localInspection
                groupName="PEN Behandling"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="no.nav.pensjon.pen.plugin.inspection.MissingForvalgtAnsvarligTeamInspection"
                displayName="Behandling subclass missing @ForvalgtAnsvarligTeam"/>
        <localInspection
                groupName="PEN Behandling"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="no.nav.pensjon.pen.plugin.inspection.MissingComponentInspection"
                displayName="AktivitetProcessor subclass missing @Component"/>
        <intentionAction>
            <className>no.nav.pensjon.pen.plugin.intention.AddAktivitetIntentionAction</className>
            <category>PEN Behandling</category>
        </intentionAction>
    </extensions>

    <actions>
        <action id="PenBehandling.NewBehandling"
                class="no.nav.pensjon.pen.plugin.action.NewBehandlingAction"
                text="PEN Behandling"
                description="Create a new Behandling with initial Aktivitet"
                icon="AllIcons.Nodes.Class">
            <add-to-group group-id="NewGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
